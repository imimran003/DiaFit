# Bind only to a private network or managed ingress in production.
PORT=8787
HOST=127.0.0.1

# Development fixture mode never calls a model and requires this bearer token.
# Set a unique local value; do not use this authentication mechanism in production.
DIAFIT_ANALYSIS_MODE=fixture
DIAFIT_DEVELOPMENT_TOKEN=replace-with-a-long-local-secret

# Meal text/image understanding: disabled, mock (offline), gemini, or openai.
# Provider credentials stay on the backend and are never shipped in the app.
DIAFIT_MEAL_PARSER_MODE=mock
GEMINI_MEAL_MODEL=gemini-3.1-flash-lite
# GEMINI_API_KEY=
OPENAI_MEAL_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=

# Maximum requests per caller per rolling minute.
RATE_LIMIT_PER_MINUTE=20
ANALYSIS_TIMEOUT_MS=12000

# A production deployment must provide a real authentication verifier and a
# server-side vision/nutrition provider. Keep provider secrets only there.
# DIAFIT_AUTH_JWKS_URL=
# VISION_PROVIDER_API_KEY=
# NUTRITION_PROVIDER_API_KEY=
